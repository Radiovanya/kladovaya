DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kladovaya?schema=public"
SESSION_SECRET="replace-with-a-long-random-secret"
ADMIN_EMAIL="admin@kladovaya.local"
ADMIN_PASSWORD_HASH="$2b$12$replace-with-bcrypt-hash"
ADMIN_NAME="Администратор"

S3_ENDPOINT="https://s3.ru1.storage.beget.cloud"
S3_REGION="ru1"
S3_BUCKET="your-private-bucket"
S3_ACCESS_KEY_ID="replace-me"
S3_SECRET_ACCESS_KEY="replace-me"
DOCUMENT_ENCRYPTION_KEY="replace-with-32-random-bytes-in-base64"

SMTP_HOST="smtp.example.ru"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="payments@example.ru"
SMTP_PASSWORD="replace-me"
SMTP_FROM="Кладовая <payments@example.ru>"
IMAP_HOST="imap.beget.com"
IMAP_PORT="993"
IMAP_SECURE="true"
IMAP_USER="payments@example.ru"
IMAP_PASSWORD="replace-me"
RECEIPT_EMAIL="payments@example.ru"
RECEIPT_CRON_SECRET="replace-with-a-long-random-secret"
